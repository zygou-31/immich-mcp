
# Immich MCP Server Configuration
# Copy this file to .env and update with your actual values

# Required Configuration
IMMICH_BASE_URL=https://your-immich-server.com/api
IMMICH_API_KEY=your-immich-api-key-here
AUTH_TOKEN=your-secret-auth-token-here

# Optional: Load secrets from files instead of environment variables
# AUTH_TOKEN_FILE=/path/to/your/auth_token.secret
# IMMICH_API_KEY_FILE=/path/to/your/immich_api_key.secret

# Optional: Server settings
IMMICH_TIMEOUT=30
IMMICH_MAX_RETRIES=3
MCP_PORT=8626
MCP_BASE_URL=""

# Development Configuration (uncomment for development)
# IMMICH_BASE_URL=http://localhost:2283/api
# IMMICH_API_KEY=dev-api-key
# AUTH_TOKEN=dev-auth-token
# IMMICH_TIMEOUT=60
