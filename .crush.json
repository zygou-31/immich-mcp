{
  "$schema": "https://charm.land/crush.json",
  "lsp": {
    "python": {
      "enabled": true,
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "options": {
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.useLibraryCodeForTypes": true,
        "python.analysis.autoImportCompletions": true
      }
    },
    "ruff": {
      "enabled": true,
      "command": "ruff",
      "args": ["server", "--preview"],
      "options": {
        "settings": {
          "lineLength": 88,
          "lint": {
            "select": ["E", "F", "I", "B", "UP"],
            "preview": true
          },
          "format": {
            "preview": true,
            "quoteStyle": "double"
          }
        }
      }
    }
  }
}

