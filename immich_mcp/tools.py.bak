
from immich_mcp.client import ImmichClient
import json

class ImmichTools:
    """Collection of tools for interacting with Immich API."""
    
    def __init__(self, client: ImmichClient):
        self.client = client
    
    async def get_all_assets(self) -> str:
        """Retrieves all assets from Immich."""
        try:
            assets = await self.client.get_all_assets()
            return json.dumps(assets)
        except Exception as e:
            return json.dumps({"error": str(e)})
    
    async def get_asset_info(self, asset_id: str) -> str:
        """Gets information about a specific asset."""
        try:
            asset = await self.client.get_asset(asset_id)
            return json.dumps(asset)
        except Exception as e:
            return json.dumps({"error": str(e)})
